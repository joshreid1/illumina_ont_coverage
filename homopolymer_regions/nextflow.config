// Process-specific configurations
process {
    // Default resources
    cpus = 2
    memory = "4.GB"
    time = "2.h"

    // Process-specific resource allocation
    withName: SUBSET_TRIO {
        cpus = 2
        memory = "8.GB"
        time = "1.h"
    }

    withName: FILTER_AC_FIRST {
        cpus = 1
        memory = "4.GB"
        time = "30.m"
    }

    withName: NORMALIZE_VARIANTS {
        cpus = 2
        memory = "8.GB"
        time = "1.h"
    }

    withName: FILTER_INDELS {
        cpus = 1
        memory = "4.GB"
        time = "30.m"
    }

    withName: FILTER_AC_SECOND {
        cpus = 1
        memory = "4.GB" 
        time = "30.m"
    }

    withName: MISSING2REF {
        cpus = 1
        memory = "4.GB"
        time = "30.m"
    }

    withName: INHERITANCE_FILTER {
        cpus = 1
        memory = "4.GB"
        time = "30.m"
    }

    withName: CREATE_HP_UNION {
        cpus = 2
        memory = "8.GB"
        time = "1.h"
    }

    withName: HP_INTERSECT {
        cpus = 2
        memory = "32.GB"
        time = "1.h"
    }

    withName: FAMILY_SUMMARY {
        cpus = 1
        memory = "2.GB"
        time = "10.m"
    }

    withName: MULTIFAMILY_SUMMARY {
        cpus = 1
        memory = "2.GB"
        time = "10.m"
    }
}

// Executor configuration
executor {
    name = 'local'
    cpus = params.max_cpus
    memory = params.max_memory
}

// Enable Docker/Singularity if available
docker {
    enabled = false
}

singularity {
    enabled = true
    autoMounts = true
}

